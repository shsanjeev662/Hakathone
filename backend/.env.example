DATABASE_URL="postgresql://your_user@localhost:5432/dhukuti_db?host=/tmp"
JWT_SECRET="replace-with-a-random-32-plus-character-secret"
NODE_ENV="development"
PORT=5000
CORS_ALLOWED_ORIGINS="http://localhost:3000"
TRUST_PROXY="false"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
USER_RATE_LIMIT_WINDOW_MS=60000
USER_RATE_LIMIT_MAX_REQUESTS=120
MEMBER_MAX_FAILED_LOGIN_ATTEMPTS=4
EMAIL_PROVIDER="gmail"
EMAIL_USER="your-gmail-address@gmail.com"
EMAIL_PASSWORD="your-gmail-app-password"
EMAIL_FROM="Smart Dhukuti <your-gmail-address@gmail.com>"
